root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs}]
indent_style = space
indent_size = 4

# Organize imports
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true

# Prefer file-scoped namespaces for new files
dotnet_style_prefer_file_scoped_namespace = true:suggestion

# var usage guidance:
# - prefer explicit types for built-in types
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning

# Naming rules: prefer PascalCase for types, methods and properties
dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum, delegate
dotnet_naming_symbols.types.applicable_accessibilities = *

dotnet_naming_symbols.methods_and_properties.applicable_kinds = method, property
dotnet_naming_symbols.methods_and_properties.applicable_accessibilities = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.types_should_be_pascal_case.severity = suggestion

dotnet_naming_rule.methods_and_properties_should_be_pascal_case.symbols = methods_and_properties
dotnet_naming_rule.methods_and_properties_should_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.methods_and_properties_should_be_pascal_case.severity = suggestion

# Treat analyzer diagnostic severity as suggestions by default; teams can escalate in CI
#dotnet_analyzer_diagnostic.severity = suggestion
dotnet_diagnostic.IDE0040.severity = warning
